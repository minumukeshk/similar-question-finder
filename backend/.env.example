# MongoDB connection string
# Local:  mongodb://localhost:27017/similar_question_finder
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/similar_question_finder

# JWT secret key — use a long, random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_secret_key

# Allowed origin for CORS (your frontend URL)
FRONTEND_URL=http://localhost:3000
